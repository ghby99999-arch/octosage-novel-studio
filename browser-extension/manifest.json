{
  "manifest_version": 3,
  "name": "OctoSage Data Sync",
  "version": "1.0.0",
  "description": "Sync author-owned visible dashboard metrics into local OctoSage.",
  "icons": {
    "16": "icons/octosage-16.png",
    "32": "icons/octosage-32.png",
    "48": "icons/octosage-48.png",
    "128": "icons/octosage-128.png"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://127.0.0.1:8787/*"],
  "action": {
    "default_title": "Sync OctoSage metrics",
    "default_icon": {
      "16": "icons/octosage-16.png",
      "32": "icons/octosage-32.png",
      "48": "icons/octosage-48.png",
      "128": "icons/octosage-128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
